generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id
  zipCode   String?
  state     String?
  country   String     @default("US")
  createdAt DateTime   @default(now())
  sightings Sighting[]
}

model Sighting {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  speciesCode String
  commonName  String
  sciName     String?
  photoUrl    String?
  latitude    Float?
  longitude   Float?
  confidence  Float?
  spottedAt   DateTime @default(now())

  @@unique([userId, speciesCode])
  @@index([userId])
}
